{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@gate/shared-types": ["./shared-types/src"],
      "@gate/analytics-engine": ["./analytics-engine/src"]
    }
  },
  "include": [
    "src/**/*",
    "shared-types/src/**/*",
    "analytics-engine/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}