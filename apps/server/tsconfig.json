{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@gate/shared-types": ["../../packages/shared-types/src"],
      "@gate/analytics-engine": ["../../packages/analytics-engine/src"]
    }
  },
  "include": ["src/**/*", "../../packages/shared-types/src/**/*", "../../packages/analytics-engine/src/**/*"],
  "exclude": ["node_modules", "dist"]
}